{
  "cluster": {
    "peername": "{{ inventory_hostname }}",
    "secret": "{{ ipfs_cluster_secret }}",
    "leave_on_shutdown": false,
    "listen_multiaddress": [
      "/ip4/0.0.0.0/tcp/9096",
      "/ip4/0.0.0.0/udp/9096/quic"
    ],
    "announce_multiaddress": [],
    "no_announce_multiaddress": [],
    "enable_relay_hop": false,
    "connection_manager": {
      "high_water": 400,
      "low_water": 100,
      "grace_period": "2m0s"
    },
    "resource_manager": {
      "enabled": true,
      "memory_limit_bytes": 0,
      "file_descriptors_limit": 0
    },
    "dial_peer_timeout": "3s",
    "state_sync_interval": "5m0s",
    "pin_recover_interval": "12m0s",
    "replication_factor_min": {{ ipfs_cluster_replication_factor_min | default(-1) | int }},
    "replication_factor_max": {{ ipfs_cluster_replication_factor_max | default(-1) | int }},
    "monitor_ping_interval": "15s",
    "peer_watch_interval": "5s",
    "mdns_interval": "0s",
    "disable_repinning": true,
    "follower_mode": false,
    "peer_addresses": [
            {% set peers = [] %}
            {% for host in groups['ipfs_cluster'] %}
            {% if hostvars[host]['ipfs_cluster_peer_addr'] is defined %}
            {% set _ = peers.append(hostvars[host]['ipfs_cluster_peer_addr']) %}
            {% endif %}
            {% endfor %}
            {% for peer in peers %}
                "{{ peer }}"{% if not loop.last %},{% endif %}
            {% endfor %}
                ]
  },
  "consensus": {
    "crdt": {
      "cluster_name": "{{ (ipfs_cluster_secret | hash('sha256'))[:16] }}",
      "trusted_peers": [
            {% set ids = [] %}
            {% for host in groups['ipfs_cluster'] %}
            {% if hostvars[host]['ipfs_cluster_peer_id'] is defined %}
            {% set _ = ids.append(hostvars[host]['ipfs_cluster_peer_id']) %}
            {% endif %}
            {% endfor %}
            {% for pid in ids %}
                    "{{ pid }}"{% if not loop.last %},{% endif %}
            {% endfor %}
                ],
      "batching": {
        "max_batch_size": 0,
        "max_batch_age": "0s"
      },
      "repair_interval": "1h0m0s"
    }
  },
  "api": {
    "ipfsproxy": {
      "listen_multiaddress": "/ip4/127.0.0.1/tcp/9095",
      "node_multiaddress": "/ip4/127.0.0.1/tcp/5001",
      "log_file": "",
      "read_timeout": "0s",
      "read_header_timeout": "5s",
      "write_timeout": "0s",
      "idle_timeout": "1m0s",
      "max_header_bytes": 4096
    },
    "restapi": {
      "http_listen_multiaddress": "/ip4/127.0.0.1/tcp/9094",
      "read_timeout": "0s",
      "read_header_timeout": "5s",
      "write_timeout": "0s",
      "idle_timeout": "2m0s",
      "max_header_bytes": 4096,
      "basic_auth_credentials": null,
      "http_log_file": "",
      "headers": {},
      "cors_allowed_origins": [],
      "cors_allowed_methods": ["GET"],
      "cors_allowed_headers": [],
      "cors_exposed_headers": ["Content-Type", "X-Stream-Output", "X-Chunked-Output", "X-Content-Length"],
      "cors_allow_credentials": false,
      "cors_max_age": "0s"
    }
  }
}